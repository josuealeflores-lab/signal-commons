# Public Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only values — never expose in client code
SUPABASE_SERVICE_ROLE_KEY=

# Test/dev-only — used by supabase/seed-reviewer.ts and test:db/test:e2e to
# provision the reviewer test fixture accounts (via plus-addressing). Not
# needed in Vercel production.
TEST_REVIEWER_EMAIL=
TEST_REVIEWER_PASSWORD=

# Optional. Used by supabase/seed-baseline-reviewer.ts and
# supabase/seed-research-queue.ts to attribute seeded baseline audit anchors
# to one inactive, non-loginable "Demo Baseline Reviewer" system identity.
# If unset, dev/CI falls back to deriving <TEST_REVIEWER_EMAIL>+baseline.
# Production setup (.env.production.local) should set this explicitly —
# default documented value: baseline@signal-commons.invalid (docs/DECISIONS.md D-075).
BASELINE_REVIEWER_EMAIL=

# Added only when the Claude extraction adapter is implemented
ANTHROPIC_API_KEY=

# Protect scheduled/manual ingestion endpoints when introduced
CRON_SECRET=
